{
    "name": "tabi/laravel-sdk",
    "description": "Laravel integration for the Tabi WhatsApp Business Messaging API (wraps tabi/sdk)",
    "license": "MIT",
    "type": "library",
    "keywords": ["tabi", "laravel", "whatsapp", "api", "sdk", "messaging"],
    "homepage": "https://tabi.africa/sdks",
    "support": {
        "docs": "https://tabi.africa/sdks"
    },
    "authors": [
        {
            "name": "Tabi",
            "homepage": "https://tabi.africa"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "tabi/sdk": "^0.3"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tabi\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tabi\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tabi\\Laravel\\TabiServiceProvider"
            ],
            "aliases": {
                "Tabi": "Tabi\\Laravel\\Facades\\Tabi"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
